PORT=5000
JWT_SECRET=change_me_to_a_long_random_string
ENCRYPTION_KEY=change_me_to_a_long_random_string

# Database mode
# embedded = portable MongoDB managed by MailForge, stored in ./data/mongodb
# external = use MONGO_URI below for Atlas or another existing MongoDB server
MAILFORGE_DB_MODE=embedded
MAILFORGE_DATA_DIR=./data
MONGOMS_DOWNLOAD_DIR=./tools/mongodb-binaries

# Optional external MongoDB. Only used when MAILFORGE_DB_MODE=external.
# MONGO_URI=mongodb://127.0.0.1:27017/mailforge
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/mailforge?appName=YourApp

# Verification engine - recommended: truemail
# truemail = truemail-go only (best SMTP server response text, fast)
# auto     = truemail-go first, Reacher fallback if Go is down
# reacher  = Reacher Docker only (best for Gmail / hard providers)
VERIFIER_ENGINE=truemail

GO_VERIFIER_URL=http://localhost:8082
VERIFIER_GO_PORT=8082
REACHER_URL=http://localhost:8081
REACHER_TIMEOUT_MS=45000
BULK_CONCURRENCY=15

# INDUS licensing
# Production/client installs require an indus-license*.json file in the app root or ./data.
# Local developer QA can bypass the subscription check with INDUS_SKIP_LICENSE=1.
# Do not enable this bypass in client deliveries.
# INDUS_SKIP_LICENSE=1

# Public URL for unsubscribe links in campaign emails
APP_BASE_URL=http://localhost:5000


# Optional SMTP proxy for verification
# SMTP_PROXY=socks5://127.0.0.1:1080

# AI template generation — Groq free tier recommended (console.groq.com)
AI_PROVIDER=groq
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
AI_MODEL=
OPENAI_MODEL=gpt-4o-mini
