{
  "name": "mailforge",
  "version": "1.1.0",
  "description": "MailForge — self-hosted email verify, campaign send, and unified inbox",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:go": "cd backend/go && go run main.go",
    "start:reacher": "docker compose up -d",
    "stop:reacher": "docker compose down",
    "start:all": "powershell -ExecutionPolicy Bypass -File scripts/start.ps1",
    "setup:go": "cd backend/go && go mod tidy",
    "setup": "npm install && npm run setup:go"
  },
  "keywords": ["email", "verification", "smtp", "campaign", "inbox", "self-hosted"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "imapflow": "^1.0.193",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^11.1.0",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
