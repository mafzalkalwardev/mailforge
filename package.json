{
  "name": "@mafzalkalwardev/mailforge",
  "version": "1.4.1",
  "description": "MailForge — self-hosted email verify, campaign send, and unified inbox",
  "main": "server.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mafzalkalwardev/mailforge.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "mongo:up": "docker compose -f docker-compose.mongo.yml up -d",
    "mongo:down": "docker compose -f docker-compose.mongo.yml down",
    "mongo:logs": "docker compose -f docker-compose.mongo.yml logs -f mongo",
    "mongo:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-mongo.ps1",
    "start:easy": "powershell -ExecutionPolicy Bypass -File scripts/start-persistent.ps1",
    "build:exe": "powershell -ExecutionPolicy Bypass -File scripts/build-exe.ps1",
    "start:persistent": "powershell -ExecutionPolicy Bypass -File scripts/start-persistent.ps1",
    "start:go": "cd backend/go && go run main.go",
    "start:reacher": "docker compose up -d",
    "stop:reacher": "docker compose down",
    "start:all": "powershell -ExecutionPolicy Bypass -File scripts/start.ps1",
    "setup:go": "cd backend/go && go mod tidy",
    "setup": "npm install && npm run setup:go",
    "setup:new-pc": "powershell -ExecutionPolicy Bypass -File scripts/setup-new-pc.ps1",
    "fix:readmes": "node scripts/fix-all-readmes.mjs",
    "restore:readmes": "node scripts/restore-readme-screenshots.mjs",
    "test": "node --test tests/*.test.js",
    "docker:full": "docker compose -f docker-compose.full.yml up -d",
    "docker:full:down": "docker compose -f docker-compose.full.yml down"
  },
  "keywords": [
    "email",
    "verification",
    "smtp",
    "campaign",
    "inbox",
    "self-hosted"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "imapflow": "^1.0.193",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^11.1.0",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "puppeteer": "^25.1.0"
  }
}
